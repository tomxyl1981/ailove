<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/light_gray">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="用户注册需知及保密协议"
            android:textSize="18sp"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《用户注册需知及保密协议》"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="尊敬的用户，欢迎您使用AiLove智能恋爱交友平台服务！在您使用本服务前，请仔细阅读并充分理解本协议全部条款。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第一条 总则"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.1 本协议是用户（以下简称&quot;您&quot;）与AiLove平台之间的法律协议。\n1.2 您点击&quot;同意&quot;按钮或实际使用本服务，即表示您已充分阅读、理解并接受本协议的全部内容。\n1.3 本协议适用于您使用AiLove平台提供的所有服务。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第二条 用户资格"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.1 您必须年满18周岁，具有完全民事行为能力。\n2.2 您保证提供的注册信息真实、准确、完整。\n2.3 未成年人使用本服务须在法定监护人陪同下进行。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第三条 用户权利"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.1 依法获得平台提供的各项服务。\n3.2 查询、更正、删除个人注册信息。\n3.3 按照平台规则参与相关活动。\n3.4 对平台服务提出意见和建议。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第四条 用户义务"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.1 遵守国家法律法规及平台各项规章制度。\n4.2 不得发布虚假、违法、有害信息。\n4.3 不得恶意刷量、作弊或干扰平台正常运营。\n4.4 保护账户安全，不得转借、转让账号。\n4.5 尊重他人合法权益，不得进行骚扰、欺诈等行为。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第五条 保密义务"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.1 您承诺对在使用服务过程中获知的其他用户信息严格保密。\n5.2 未经信息主体明确授权，不得向任何第三方泄露用户个人信息。\n5.3 不得以任何方式收集、存储、传播其他用户的私人信息。\n5.4 不得利用获取的信息从事商业推广或其他营利活动。\n5.5 发现信息安全风险时，应及时向平台报告。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第六条 服务内容"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6.1 提供基于AI技术的智能匹配服务。\n6.2 提供个人画像分析和情感咨询服务。\n6.3 提供安全可靠的即时通讯服务。\n6.4 定期举办线上线下交友活动。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第七条 免责声明"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7.1 平台提供的匹配建议仅供参考，不构成任何形式的承诺或保证。\n7.2 因用户个人行为导致的任何后果，平台不承担法律责任。\n7.3 用户应自行判断交往对象的真实性、可靠性和安全性。\n7.4 因不可抗力因素导致的服务中断，平台不承担责任。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第八条 违约处理"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8.1 违反本协议的用户，平台有权采取警告、限制功能、封禁账号等措施。\n8.2 情节严重的，平台有权追究相应的法律责任。\n8.3 用户违规行为造成平台损失的，应承担赔偿责任。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第九条 协议变更"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9.1 平台有权根据法律法规变化或业务发展需要修改本协议。\n9.2 修改后的协议将通过公告等方式提前通知用户。\n9.3 如您继续使用服务，视为接受修改后的协议。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第十条 争议解决"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10.1 因本协议产生的争议，双方应友好协商解决。\n10.2 协商不成的，任何一方可向平台所在地人民法院提起诉讼。"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="特别提示：请您务必审慎阅读、充分理解本协议各条款内容，特别是免除或者限制责任的条款。如您对协议有任何疑问，可通过客服渠道咨询。点击同意即表示您已完全理解并接受本协议。"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white">

        <CheckBox
            android:id="@+id/cb_agree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我已完整阅读并同意上述协议条款"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="确认同意"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

</LinearLayout>