<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标签页导航 -->
        <LinearLayout
            android:id="@+id/ll_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="8dp">

            <Button
                android:id="@+id/btn_tab_overall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="综合评分" />

            <Button
                android:id="@+id/btn_tab_bazi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="八字匹配系统" />

            <Button
                android:id="@+id/btn_tab_constellation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="星座匹配系统" />

            <Button
                android:id="@+id/btn_tab_mbti"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="MBTI 匹配" />

            <Button
                android:id="@+id/btn_tab_bigfive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="大五人格" />
        </LinearLayout>

        <!-- Like/Dislike 反馈按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_like"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="点赞 ✓" />

            <Button
                android:id="@+id/btn_dislike"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="点不推荐 ✕" />
        </LinearLayout>

        <!-- 综合评分显示区域 -->
        <LinearLayout
            android:id="@+id/ll_overall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="综合评分（权重：八字 20% + 星座 15% + MBTI 25% + 大五 30% + 其他 10%）" />

            <TextView
                android:id="@+id/tv_overall_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="综合评分：0" />

            <TextView
                android:id="@+id/tv_overall_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="详细解读：" />
        </LinearLayout>

        <!-- 八字匹配系统 -->
        <LinearLayout
            android:id="@+id/ll_bazi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="八字匹配系统"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_bazi_birth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="出生年月日时（如：1990-03-15）" />

            <RadioGroup
                android:id="@+id/rg_bazi_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_bazi_m"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="男" />

                <RadioButton
                    android:id="@+id/rb_bazi_f"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="女" />
            </RadioGroup>

            <Button
                android:id="@+id/btn_bazi_calc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算合婚评分" />

            <TextView
                android:id="@+id/tv_bazi_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="合婚评分：0" />

            <TextView
                android:id="@+id/tv_bazi_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- 星座匹配系统 -->
        <LinearLayout
            android:id="@+id/ll_constellation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="星座匹配系统"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_constellation_birth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="出生日期（如：1990-03）" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="太阳星座：" />

            <Spinner
                android:id="@+id/sp_sun_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/zodiac_suns" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="月亮星座：" />

            <Spinner
                android:id="@+id/sp_moon_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/zodiac_moons" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上升星座：" />

            <Spinner
                android:id="@+id/sp_rising_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/zodiac_risings" />

            <Button
                android:id="@+id/btn_constellation_calc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算星座匹配" />

            <TextView
                android:id="@+id/tv_constellation_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="星座匹配：0" />

            <TextView
                android:id="@+id/tv_constellation_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- MBTI 人格测试匹配 -->
        <LinearLayout
            android:id="@+id/ll_mbti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MBTI 人格测试匹配（60 题，15 分钟完成）"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="能量来源：外向 (E) vs 内向 (I)" />

            <Spinner
                android:id="@+id/sp_mbti_ei"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/mbti_ei" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信息收集：感觉 (S) vs 直觉 (N)" />

            <Spinner
                android:id="@+id/sp_mbti_sn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/mbti_sn" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="决策方式：思维 (T) vs 情感 (F)" />

            <Spinner
                android:id="@+id/sp_mbti_tf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/mbti_tf" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="生活态度：判断 (J) vs 感知 (P)" />

            <Spinner
                android:id="@+id/sp_mbti_jp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:entries="@array/mbti_jp" />

            <Button
                android:id="@+id/btn_mbti_test"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算 MBTI 匹配" />

            <TextView
                android:id="@+id/tv_mbti_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="官配契合：0" />

            <TextView
                android:id="@+id/tv_mbti_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- 大五人格 OCEAN -->
        <LinearLayout
            android:id="@+id/ll_bigfive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="大五人格 OCEAN（5 维雷达图）"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="开放性 (Openness)：" />

                <SeekBar
                    android:id="@+id/sb_openness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="尽责性 (Conscientiousness)：" />

                <SeekBar
                    android:id="@+id/sb_conscientious"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="外向性 (Extraversion)：" />

                <SeekBar
                    android:id="@+id/sb_extraversion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="宜人性 (Agreeableness)：" />

                <SeekBar
                    android:id="@+id/sb_agreeableness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="神经质 (Neuroticism)：" />

                <SeekBar
                    android:id="@+id/sb_neuroticism"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_bigfive_calc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="计算大五人格评分" />

            <TextView
                android:id="@+id/tv_bigfive_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="大五人格评分：0" />

            <TextView
                android:id="@+id/tv_bigfive_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>