<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="认证中心"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_overview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textColor="#FF555555" />

        <!-- 手机绑定 -->
        <LinearLayout
            android:id="@+id/item_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机绑定"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_phone_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 去绑定 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 身份证实名认证 -->
        <LinearLayout
            android:id="@+id/item_identity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="身份证实名认证"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="姓名" />
            <EditText
                android:id="@+id/et_idcard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="身份证号码" />
            <TextView
                android:id="@+id/btn_identity_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 开始实名认证 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 真实颜原相机照片视频认证 -->
        <LinearLayout
            android:id="@+id/item_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="真实颜原相机照片视频认证"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_photo_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 拍照认证(原相机模式) ---"
                android:textColor="#FF888888" />
            <TextView
                android:id="@+id/btn_video_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 视频认证(30秒自我介绍) ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 车辆认证 -->
        <LinearLayout
            android:id="@+id/item_vehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="车辆认证"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_vehicle_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 行驶证认证 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 学历认证 -->
        <LinearLayout
            android:id="@+id/item_education"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="学历认证"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_education_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 学信网对接 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 资产认证 -->
        <LinearLayout
            android:id="@+id/item_assets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="个人存款资产认证"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_assets_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 资产认证 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

        <!-- 技能证书 -->
        <LinearLayout
            android:id="@+id/item_certificates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/light_gray"
            android:padding="12dp"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="技能证书与获奖证书"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/btn_certificates_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_cert_button"
                android:text="--- 证书验证 ---"
                android:textColor="#FF888888" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
