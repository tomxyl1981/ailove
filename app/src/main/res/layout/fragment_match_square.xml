<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
    <TextView android:id="@+id/tv_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="匹配广场" android:textSize="20sp" android:textStyle="bold"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="8dp" android:paddingBottom="8dp">
      <Button android:id="@+id/btn_tab_bazi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="八字匹配系统"/>
      <Button android:id="@+id/btn_tab_constellation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="星座匹配系统"/>
      <Button android:id="@+id/btn_tab_mbti" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="MBTI 匹配"/>
      <Button android:id="@+id/btn_tab_bigfive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="大五人格"/>
    </LinearLayout>
    <!-- BaZi 对应区块 -->
    <LinearLayout android:id="@+id/ll_bazi" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
      <TextView android:text="八字匹配系统" android:textStyle="bold"/>
      <EditText android:id="@+id/et_bazi_birth" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="出生年月日时"/>
      <EditText android:id="@+id/et_bazi_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="出生时间（HH:mm）"/>
      <RadioGroup android:id="@+id/rg_bazi_gender" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
        <RadioButton android:id="@+id/rb_bazi_m" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="男"/>
        <RadioButton android:id="@+id/rb_bazi_f" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="女"/>
      </RadioGroup>
      <Button android:id="@+id/btn_bazi_calc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="计算合婚评分"/>
      <TextView android:id="@+id/tv_bazi_score" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="合婚评分：-"/>
      <TextView android:id="@+id/tv_bazi_radar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="雷达图占位"/>
      <TextView android:id="@+id/tv_bazi_details" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="详细解读：-"/>
    </LinearLayout>
    <!-- 星座、MBTI、大五等区块（简化为占位） -->
    <LinearLayout android:id="@+id/ll_constellation" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
      <EditText android:id="@+id/et_constellation_birth" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="出生日期" />
      <SeekBar android:id="@+id/sb_openness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
      <SeekBar android:id="@+id/sb_conscientious" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
      <SeekBar android:id="@+id/sb_extraversion" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
      <SeekBar android:id="@+id/sb_agreeableness" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
      <SeekBar android:id="@+id/sb_neuroticism" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100"/>
      <Spinner android:id="@+id/sp_mbti_ei" android:layout_width="match_parent" android:layout_height="wrap_content"/>
      <Spinner android:id="@+id/sp_mbti_sn" android:layout_width="match_parent" android:layout_height="wrap_content"/>
      <Spinner android:id="@+id/sp_mbti_tf" android:layout_width="match_parent" android:layout_height="wrap_content"/>
      <Spinner android:id="@+id/sp_mbti_jp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
      <Button android:id="@+id/btn_constellation_calc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="计算星座匹配"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/ll_mbti" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="visible"/>
    <LinearLayout android:id="@+id/ll_bigfive" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="visible"/>
    <TextView android:id="@+id/tv_overall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="综合评分：-"/>
    <TextView android:id="@+id/tv_details" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="维度分解：-"/>
    <Button android:id="@+id/btn_save_all_match" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="保存综合结果"/>
  </LinearLayout>
</ScrollView>
