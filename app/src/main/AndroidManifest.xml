<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 基本网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 调试相关权限 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- Android 13+ 通知权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 获取手机号码相关权限 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    
    <!-- 真机调试优化配置 -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AiLove"
        android:usesCleartextTraffic="true"
        android:debuggable="true">
        
        <!-- 认证中心相关活动（演示/扩展） -->
        <activity android:name="com.ailove.app.ui.activity.CameraCertificationActivity"/>
        <activity android:name="com.ailove.app.ui.activity.CertificationQuestionnaireActivity"/>
        <activity android:name="com.ailove.app.ui.activity.CertificationHistoryActivity"/>
        <activity android:name="com.ailove.app.ui.activity.MatchPlazaActivity"/>
        <activity android:name="com.ailove.app.ui.activity.MatchSectionActivity"/>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths"/>
        </provider>
        
        <!-- 为所有Activity添加调试标志 -->
        <activity
            android:name=".ui.activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AiLove"
            android:debuggable="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.activity.WelcomeActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.AIChatActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.MatchResultActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.GroupChatActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.PrivateChatActivity"
            android:exported="false"
            android:debuggable="true" />

        <!-- 新增的Activity声明 -->
        <activity
            android:name=".ui.activity.RealNameVerifyActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.ProfileAnalysisActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.SolemnVerifyActivity"
            android:exported="false"
            android:debuggable="true" />

        <!-- 用户协议和隐私政策Activity -->
        <activity
            android:name=".ui.activity.UserProtocolActivity"
            android:exported="false"
            android:debuggable="true" />

        <activity
            android:name=".ui.activity.PrivacyPolicyActivity"
            android:exported="false"
            android:debuggable="true" />

        <!-- 邮箱登录Activity -->
        <activity
            android:name=".ui.activity.EmailLoginActivity"
            android:exported="false"
            android:debuggable="true" />

        <!-- 设置Activity -->
        <activity
            android:name=".ui.activity.SettingsActivity"
            android:exported="false"
            android:debuggable="true" />

        <!-- 手机设置Activity -->
        <activity
            android:name=".ui.activity.PhoneSettingsActivity"
            android:exported="false"
            android:debuggable="true" />

    </application>

</manifest>
